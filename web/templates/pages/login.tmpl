{{define "login"}}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Auth API Admin</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cpath d='M16 1L3 7v8c0 8 5 14 13 16 8-2 13-8 13-16V7Z' fill='%23212529'/%3E%3Crect x='12' y='14' width='8' height='7' rx='1.5' fill='%23fff'/%3E%3Cpath d='M13.5 14v-2.5a2.5 2.5 0 0 1 5 0V14' fill='none' stroke='%23fff' stroke-width='1.8'/%3E%3C/svg%3E">
    <link rel="stylesheet" href="/gui/static/css/bootstrap.min.css">
    <link rel="stylesheet" href="/gui/static/css/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .login-card {
            width: 100%;
            max-width: 420px;
        }
        .divider {
            display: flex;
            align-items: center;
            margin: 1rem 0;
        }
        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #dee2e6;
        }
        .divider span {
            padding: 0 0.75rem;
            color: #6c757d;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock text-primary" style="font-size: 3rem;"></i>
            <h3 class="mt-2 fw-bold">Auth API</h3>
            <p class="text-muted">Admin Panel</p>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                {{if .Error}}
                <div class="alert alert-danger py-2" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i>{{.Error}}
                </div>
                {{end}}

                <div id="passkey-error" class="alert alert-danger py-2 d-none" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i><span id="passkey-error-msg"></span>
                </div>

                <form method="POST" action="/gui/login">
                    <input type="hidden" name="_csrf" value="{{.CSRFToken}}">
                    {{if .Redirect}}
                    <input type="hidden" name="redirect" value="{{.Redirect}}">
                    {{end}}

                    <div class="mb-3">
                        <label for="username" class="form-label">
                            <i class="bi bi-person me-1"></i>Username or Email
                        </label>
                        <input type="text" class="form-control" id="username" name="username"
                               value="{{.Username}}" placeholder="Enter username or email"
                               autocomplete="username" autofocus required>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label">
                            <i class="bi bi-lock me-1"></i>Password
                        </label>
                        <input type="password" class="form-control" id="password" name="password"
                               placeholder="Enter password"
                               autocomplete="current-password" required>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                    </button>
                </form>

                <div id="passkey-section" style="display:none;">
                    <div class="divider"><span>or</span></div>

                    <button type="button" id="passkey-login-btn" class="btn btn-outline-secondary w-100"
                            onclick="loginWithPasskey()">
                        <i class="bi bi-fingerprint me-1"></i>Sign in with Passkey
                    </button>
                </div>

                <div id="magic-link-section">
                    <div class="divider"><span>or</span></div>

                    <div id="magic-link-form">
                        <div class="input-group">
                            <input type="email" class="form-control" id="magic-link-email"
                                   placeholder="Enter your email address" autocomplete="email">
                            <button type="button" class="btn btn-outline-primary" id="magic-link-btn"
                                    onclick="requestMagicLink()">
                                <i class="bi bi-link-45deg me-1"></i>Magic Link
                            </button>
                        </div>
                    </div>
                    <div id="magic-link-result" class="mt-2"></div>
                </div>
            </div>
        </div>

        <p class="text-center text-muted mt-3 small">
            Auth API Admin Panel &bull; Secure Access Only
        </p>
    </div>

    <script src="/gui/static/js/bootstrap.bundle.min.js"></script>
    <script>
    // Feature detection: only show passkey button if WebAuthn is supported
    if (window.PublicKeyCredential) {
        document.getElementById('passkey-section').style.display = 'block';
    }

    // Helper: base64url encode ArrayBuffer
    function bufferToBase64url(buffer) {
        var bytes = new Uint8Array(buffer);
        var str = '';
        for (var i = 0; i < bytes.byteLength; i++) {
            str += String.fromCharCode(bytes[i]);
        }
        return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }

    // Helper: base64url decode to Uint8Array
    function base64urlToBuffer(base64url) {
        var base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
        while (base64.length % 4) base64 += '=';
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) {
            bytes[i] = binary.charCodeAt(i);
        }
        return bytes;
    }

    function showPasskeyError(msg) {
        var el = document.getElementById('passkey-error');
        var msgEl = document.getElementById('passkey-error-msg');
        if (msg) {
            msgEl.textContent = msg;
            el.classList.remove('d-none');
        } else {
            el.classList.add('d-none');
            msgEl.textContent = '';
        }
    }

    async function loginWithPasskey() {
        var btn = document.getElementById('passkey-login-btn');
        btn.disabled = true;
        showPasskeyError('');

        try {
            // Step 1: Begin — get WebAuthn options from server
            var beginResp = await fetch('/gui/passkey-login/begin', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'}
            });
            if (!beginResp.ok) {
                var beginErr = await beginResp.json().catch(function() { return {}; });
                throw new Error(beginErr.error || 'Failed to start passkey login');
            }
            var beginData = await beginResp.json();

            var options = beginData.options;
            var sessionID = beginData.session_id;

            // Step 2: Decode challenge and allowCredentials from base64url
            options.publicKey.challenge = base64urlToBuffer(options.publicKey.challenge);
            if (options.publicKey.allowCredentials) {
                for (var i = 0; i < options.publicKey.allowCredentials.length; i++) {
                    options.publicKey.allowCredentials[i].id = base64urlToBuffer(options.publicKey.allowCredentials[i].id);
                }
            }

            // Step 3: Call browser WebAuthn API (discoverable credential)
            var assertion = await navigator.credentials.get(options);

            // Step 4: Encode response for server
            var assertionResponse = {
                id: assertion.id,
                rawId: bufferToBase64url(assertion.rawId),
                type: assertion.type,
                response: {
                    authenticatorData: bufferToBase64url(assertion.response.authenticatorData),
                    clientDataJSON: bufferToBase64url(assertion.response.clientDataJSON),
                    signature: bufferToBase64url(assertion.response.signature)
                }
            };
            if (assertion.response.userHandle) {
                assertionResponse.response.userHandle = bufferToBase64url(assertion.response.userHandle);
            }

            // Step 5: Finish — send assertion to server
            var finishResp = await fetch('/gui/passkey-login/finish', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    session_id: sessionID,
                    credential: assertionResponse
                })
            });
            if (!finishResp.ok) {
                var finishErr = await finishResp.json().catch(function() { return {}; });
                throw new Error(finishErr.error || 'Passkey verification failed');
            }

            var result = await finishResp.json();
            window.location.href = result.redirect || '/gui/';

        } catch (err) {
            if (err.name === 'NotAllowedError') {
                showPasskeyError('Passkey authentication was cancelled or timed out.');
            } else if (err.name === 'AbortError') {
                // User cancelled — don't show error
            } else {
                showPasskeyError(err.message || 'Passkey login failed. Please try again.');
            }
            btn.disabled = false;
        }
    }

    async function requestMagicLink() {
        var btn = document.getElementById('magic-link-btn');
        var emailInput = document.getElementById('magic-link-email');
        var resultDiv = document.getElementById('magic-link-result');
        var email = emailInput.value.trim();

        if (!email) {
            resultDiv.innerHTML = '<div class="alert alert-warning py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>Please enter your email address.</div>';
            return;
        }

        btn.disabled = true;
        resultDiv.innerHTML = '<div class="alert alert-info py-2 small"><i class="bi bi-hourglass-split me-1"></i>Sending magic link...</div>';

        try {
            var resp = await fetch('/gui/magic-link-login', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: 'email=' + encodeURIComponent(email)
            });

            var data = await resp.json();

            if (resp.ok) {
                resultDiv.innerHTML = '<div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i>' + data.message + '</div>';
            } else {
                resultDiv.innerHTML = '<div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>' + (data.error || 'Request failed. Please try again.') + '</div>';
                btn.disabled = false;
            }
        } catch (err) {
            resultDiv.innerHTML = '<div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>Request failed. Please try again.</div>';
            btn.disabled = false;
        }
    }
    </script>
</body>
</html>
{{end}}
