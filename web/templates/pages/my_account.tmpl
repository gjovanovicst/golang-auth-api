{{define "my_account"}}
{{template "base" .}}
{{end}}

{{define "title"}}My Account{{end}}

{{define "content"}}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-person-gear me-2"></i>My Account
    </h4>
</div>

<div class="row g-4">
    <!-- Left column: Email & Password -->
    <div class="col-lg-6">
        <!-- Email Address Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-envelope me-2"></i>Email Address</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Your email is used for email-based two-factor authentication and account recovery notifications.
                </p>
                <form hx-post="/gui/my-account/email" hx-target="#email-result" hx-swap="innerHTML">
                    <input type="hidden" name="_csrf" value="{{.CSRFToken}}">
                    <div class="mb-3">
                        <label for="email" class="form-label small">Email Address</label>
                        <input type="email" class="form-control" id="email" name="email"
                               value="{{.Data.Email}}" placeholder="admin@example.com" required>
                    </div>
                    <div id="email-result"></div>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-check-lg me-1"></i>Update Email
                    </button>
                </form>
            </div>
        </div>

        <!-- Change Password Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-lock me-2"></i>Change Password</h6>
            </div>
            <div class="card-body">
                <form hx-post="/gui/my-account/password" hx-target="#password-result" hx-swap="innerHTML">
                    <input type="hidden" name="_csrf" value="{{.CSRFToken}}">
                    <div class="mb-3">
                        <label for="current_password" class="form-label small">Current Password</label>
                        <input type="password" class="form-control" id="current_password"
                               name="current_password" autocomplete="current-password" required>
                    </div>
                    <div class="mb-3">
                        <label for="new_password" class="form-label small">New Password</label>
                        <input type="password" class="form-control" id="new_password"
                               name="new_password" minlength="8" autocomplete="new-password" required>
                        <div class="form-text">Minimum 8 characters.</div>
                    </div>
                    <div class="mb-3">
                        <label for="confirm_password" class="form-label small">Confirm New Password</label>
                        <input type="password" class="form-control" id="confirm_password"
                               name="confirm_password" minlength="8" autocomplete="new-password" required>
                    </div>
                    <div id="password-result"></div>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-key me-1"></i>Change Password
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right column: 2FA Settings & Passkeys -->
    <div class="col-lg-6">
        <!-- 2FA Status Section (HTMX-driven) -->
        <div id="twofa-section"
             hx-get="/gui/my-account/2fa/status"
             hx-trigger="load"
             hx-swap="innerHTML">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2 text-muted small">Loading 2FA status...</span>
                </div>
            </div>
        </div>

        <!-- 2FA Setup Area (populated by HTMX when setting up) -->
        <div id="twofa-setup-area" class="mt-4"></div>

        <!-- Passkey Section (HTMX-driven) -->
        <div id="passkey-section" class="mt-4"
             hx-get="/gui/my-account/passkeys/status"
             hx-trigger="load"
             hx-swap="innerHTML">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2 text-muted small">Loading passkey status...</span>
                </div>
            </div>
        </div>

        <!-- Magic Link Section (HTMX-driven) -->
        <div id="magic-link-section" class="mt-4"
             hx-get="/gui/my-account/magic-link/status"
             hx-trigger="load"
             hx-swap="innerHTML">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2 text-muted small">Loading magic link status...</span>
                </div>
            </div>
        </div>
    </div>
</div>
{{end}}

{{define "scripts"}}
<script>
    // Listen for 2FA status refresh events
    document.body.addEventListener('2faStatusRefresh', function() {
        htmx.trigger(document.getElementById('twofa-section'), 'load');
    });

    // ====================================================================
    // WebAuthn Passkey Registration
    // ====================================================================

    // Helper: base64url encode ArrayBuffer
    function bufferToBase64url(buffer) {
        var bytes = new Uint8Array(buffer);
        var str = '';
        for (var i = 0; i < bytes.byteLength; i++) {
            str += String.fromCharCode(bytes[i]);
        }
        return btoa(str).replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }

    // Helper: base64url decode to Uint8Array
    function base64urlToBuffer(base64url) {
        var base64 = base64url.replace(/-/g, '+').replace(/_/g, '/');
        while (base64.length % 4) base64 += '=';
        var binary = atob(base64);
        var bytes = new Uint8Array(binary.length);
        for (var i = 0; i < binary.length; i++) {
            bytes[i] = binary.charCodeAt(i);
        }
        return bytes;
    }

    function showPasskeyMsg(msg, type) {
        var el = document.getElementById('passkey-status-msg');
        if (el) {
            el.innerHTML = '<div class="alert alert-' + type + ' py-2 small">' + msg + '</div>';
        }
    }

    async function registerPasskey() {
        var btn = document.getElementById('register-passkey-btn');
        if (btn) btn.disabled = true;
        showPasskeyMsg('Starting passkey registration...', 'info');

        // Prompt for passkey name
        var passkeyName = prompt('Enter a name for this passkey (e.g., "MacBook Touch ID", "YubiKey"):');
        if (passkeyName === null) {
            if (btn) btn.disabled = false;
            showPasskeyMsg('', 'info');
            document.getElementById('passkey-status-msg').innerHTML = '';
            return;
        }
        passkeyName = passkeyName.trim();

        try {
            // Step 1: Begin registration — get options from server
            var beginResp = await fetch('/gui/my-account/passkeys/register/begin', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: '_csrf={{.CSRFToken}}'
            });
            if (!beginResp.ok) {
                var errText = await beginResp.text();
                throw new Error(errText || 'Failed to start registration');
            }
            var options = await beginResp.json();

            // Step 2: Decode challenge and user.id from base64url
            options.publicKey.challenge = base64urlToBuffer(options.publicKey.challenge);
            options.publicKey.user.id = base64urlToBuffer(options.publicKey.user.id);
            if (options.publicKey.excludeCredentials) {
                for (var i = 0; i < options.publicKey.excludeCredentials.length; i++) {
                    options.publicKey.excludeCredentials[i].id = base64urlToBuffer(options.publicKey.excludeCredentials[i].id);
                }
            }

            // Step 3: Call browser WebAuthn API
            showPasskeyMsg('Touch your security key or use biometrics...', 'info');
            var credential = await navigator.credentials.create(options);

            // Step 4: Encode response for server
            var attestationResponse = {
                id: credential.id,
                rawId: bufferToBase64url(credential.rawId),
                type: credential.type,
                response: {
                    attestationObject: bufferToBase64url(credential.response.attestationObject),
                    clientDataJSON: bufferToBase64url(credential.response.clientDataJSON)
                }
            };
            // Include transports if available
            if (credential.response.getTransports) {
                attestationResponse.response.transports = credential.response.getTransports();
            }

            // Step 5: Finish registration on server
            var finishResp = await fetch('/gui/my-account/passkeys/register/finish', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: '_csrf={{.CSRFToken}}&name=' + encodeURIComponent(passkeyName) + '&credential=' + encodeURIComponent(JSON.stringify(attestationResponse))
            });
            if (!finishResp.ok) {
                var errText2 = await finishResp.text();
                throw new Error(errText2 || 'Failed to complete registration');
            }

            showPasskeyMsg('Passkey registered successfully!', 'success');

            // Refresh the passkey list
            htmx.ajax('GET', '/gui/my-account/passkeys/status', {target: '#passkey-section', swap: 'innerHTML'});

        } catch (err) {
            if (err.name === 'NotAllowedError') {
                showPasskeyMsg('Registration cancelled or timed out.', 'warning');
            } else {
                showPasskeyMsg('Registration failed: ' + err.message, 'danger');
            }
        } finally {
            if (btn) btn.disabled = false;
        }
    }

    async function renamePasskey(passkeyId, btnEl) {
        var newName = prompt('Enter a new name for this passkey:');
        if (newName === null || newName.trim() === '') return;

        try {
            var resp = await fetch('/gui/my-account/passkeys/' + passkeyId + '/rename', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: '_csrf={{.CSRFToken}}&name=' + encodeURIComponent(newName.trim())
            });
            if (!resp.ok) {
                var errText = await resp.text();
                throw new Error(errText || 'Failed to rename passkey');
            }
            // Refresh the passkey list
            htmx.ajax('GET', '/gui/my-account/passkeys/status', {target: '#passkey-section', swap: 'innerHTML'});
        } catch (err) {
            alert('Failed to rename passkey: ' + err.message);
        }
    }
</script>
{{end}}
