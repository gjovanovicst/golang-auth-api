{{define "oidc_logout"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signed Out — {{.AppName}}</title>
    <link rel="stylesheet" href="/gui/static/css/bootstrap.min.css">
    <link rel="stylesheet" href="/gui/static/css/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .logout-card { width: 100%; max-width: 420px; }
    </style>
</head>
<body>
<div class="container py-5">
    <div class="logout-card mx-auto">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <i class="bi bi-box-arrow-right text-secondary" style="font-size: 3rem;"></i>
                <h4 class="card-title mt-3 mb-2">You have been signed out</h4>
                <p class="text-muted mb-4">Your session with <strong>{{.AppName}}</strong> has ended.</p>
                <hr class="my-4">
                <p class="text-muted" style="font-size: 0.75rem;">
                    Powered by <strong>{{.AppName}}</strong> authentication
                </p>
            </div>
        </div>
    </div>
</div>
</body>
</html>
{{end}}
