{{define "settings"}}
{{template "base" .}}
{{end}}

{{define "title"}}Settings{{end}}

{{define "head"}}
<style>
    .setting-row {
        border-bottom: 1px solid var(--bs-border-color);
        padding: 0.75rem 0;
    }
    .setting-row:last-child {
        border-bottom: none;
    }
    .source-badge {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.02em;
    }
    .setting-value-input {
        max-width: 400px;
    }
    .restart-badge {
        font-size: 0.65rem;
    }
    .system-info-card .info-item {
        padding: 0.4rem 0;
        border-bottom: 1px solid var(--bs-border-color-translucent);
    }
    .system-info-card .info-item:last-child {
        border-bottom: none;
    }
    .accordion-button:not(.collapsed) {
        background-color: rgba(var(--bs-primary-rgb), 0.05);
    }
    .sensitive-toggle {
        cursor: pointer;
    }

    /* ── Tag-chip widget ───────────────────────────────────────────── */
    .tag-input-wrapper {
        max-width: 560px;
    }
    .tag-input-box {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        align-items: center;
        height: auto;
        min-height: calc(1.5em + 0.5rem + 2px); /* matches form-control-sm height */
        cursor: text;
        padding: 0.3rem 0.5rem;
    }
    .tag-input-box:focus-within {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }
    .tag-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        background: var(--bs-primary-bg-subtle);
        color: var(--bs-primary-text-emphasis);
        border: 1px solid var(--bs-primary-border-subtle);
        border-radius: 0.25rem;
        padding: 0.1rem 0.35rem;
        font-size: 0.78rem;
        white-space: nowrap;
        line-height: 1.4;
    }
    .tag-chip .tag-remove {
        cursor: pointer;
        opacity: 0.55;
        font-size: 1rem;
        line-height: 1;
        border: none;
        background: none;
        padding: 0 0 0.05rem 0;
        color: inherit;
        transition: opacity 0.1s;
        flex-shrink: 0;
    }
    .tag-chip .tag-remove:hover { opacity: 1; }
    .tag-draft {
        border: none;
        outline: none;
        background: transparent;
        font-size: 0.82rem;
        min-width: 9rem;
        flex: 1;
        padding: 0;
        line-height: 1.4;
    }
    /* Read-only chip display for ENV-sourced tag_list settings */
    .tag-chip-ro {
        background: var(--bs-secondary-bg-subtle);
        color: var(--bs-secondary-text-emphasis);
        border: 1px solid var(--bs-secondary-border-subtle);
        border-radius: 0.25rem;
        padding: 0.1rem 0.4rem;
        font-size: 0.78rem;
        font-weight: 400;
    }
</style>
{{end}}

{{define "content"}}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="bi bi-gear me-2"></i>System Settings
    </h4>
</div>

<!-- System Info Card (lazy-loaded via HTMX) -->
<div id="system-info-container"
     hx-get="/gui/settings/info"
     hx-trigger="load"
     hx-swap="innerHTML">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body text-center py-3">
            <div class="spinner-border spinner-border-sm text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="ms-2 text-muted small">Loading system info...</span>
        </div>
    </div>
</div>

<!-- Settings Accordion -->
<div class="accordion" id="settingsAccordion">
    {{range $i, $cat := .Data}}
    <div class="accordion-item border-0 shadow-sm mb-2 rounded">
        <h2 class="accordion-header" id="heading-{{$cat.Slug}}">
            <button class="accordion-button collapsed rounded" type="button"
                    data-bs-toggle="collapse" data-bs-target="#collapse-{{$cat.Slug}}"
                    aria-expanded="false" aria-controls="collapse-{{$cat.Slug}}">
                <i class="{{$cat.Icon}} me-2"></i>
                <span class="fw-semibold">{{$cat.Label}}</span>
                <span class="badge bg-secondary-subtle text-secondary ms-2">{{len $cat.Settings}}</span>
            </button>
        </h2>
        <div id="collapse-{{$cat.Slug}}" class="accordion-collapse collapse"
             aria-labelledby="heading-{{$cat.Slug}}" data-bs-parent="#settingsAccordion">
            <div class="accordion-body p-0"
                 id="section-{{$cat.Slug}}"
                 hx-get="/gui/settings/section/{{$cat.Slug}}"
                 hx-trigger="shown.bs.collapse from:closest .accordion-item"
                 hx-swap="innerHTML">
                <!-- Loaded on accordion expand -->
                <div class="text-center py-4">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2 text-muted small">Loading settings...</span>
                </div>
            </div>
        </div>
    </div>
    {{end}}
</div>

<!-- Alert container for save/reset feedback (positioned fixed) -->
<div id="settings-alert" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1055;"></div>
{{end}}

{{define "scripts"}}
<script>
    // Toggle password visibility for sensitive fields
    function toggleSensitive(key) {
        var input = document.getElementById('setting-input-' + key);
        var icon = document.getElementById('sensitive-icon-' + key);
        if (input.type === 'password') {
            input.type = 'text';
            icon.className = 'bi bi-eye-slash';
        } else {
            input.type = 'password';
            icon.className = 'bi bi-eye';
        }
    }

    // Show a toast-like alert at the bottom
    function showSettingsAlert(message, type) {
        var container = document.getElementById('settings-alert');
        var alertHtml = '<div class="alert alert-' + type + ' alert-dismissible fade show shadow" role="alert">' +
            '<small>' + message + '</small>' +
            '<button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>' +
            '</div>';
        container.innerHTML = alertHtml;
        // Auto-dismiss after 3s
        setTimeout(function() {
            var alert = container.querySelector('.alert');
            if (alert) {
                var bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                bsAlert.close();
            }
        }, 3000);
    }

    // Handle HTMX events for settings feedback
    document.body.addEventListener('settingSaved', function(e) {
        showSettingsAlert('Setting saved successfully.', 'success');
    });
    document.body.addEventListener('settingReset', function(e) {
        showSettingsAlert('Setting reset to default.', 'info');
    });
    document.body.addEventListener('settingError', function(e) {
        var msg = e.detail && e.detail.message ? e.detail.message : 'An error occurred.';
        showSettingsAlert(msg, 'danger');
    });

    // ── Tag-chip widget ──────────────────────────────────────────────
    //
    // initTagInput(boxId, hiddenId)
    //   boxId    — id of the visible .tag-input-box div
    //   hiddenId — id of the hidden <input name="value"> that the form submits
    //
    // Behaviour:
    //   • Existing comma-separated values are rendered as removable chips on load.
    //   • User types in the inline draft input; Enter adds a chip, × removes it.
    //   • Backspace on an empty draft removes the last chip.
    //   • Escape clears the draft without adding.
    //   • Every mutation syncs chips back to the hidden input as a comma-separated
    //     string, so the standard hx-put form submit sends the correct value.
    function initTagInput(boxId, hiddenId) {
        var box    = document.getElementById(boxId);
        var hidden = document.getElementById(hiddenId);
        if (!box || !hidden) return;
        // Prevent double-init
        if (box.dataset.initialized === '1') return;
        box.dataset.initialized = '1';

        var values = hidden.value
            ? hidden.value.split(',').map(function(s){ return s.trim(); }).filter(Boolean)
            : [];

        function escapeHTML(str) {
            return str
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function sync() {
            hidden.value = values.join(',');
        }

        function render() {
            // Preserve draft text across re-renders
            var existing = box.querySelector('.tag-draft');
            var draftVal = existing ? existing.value : '';

            box.innerHTML = '';

            values.forEach(function(v, i) {
                var chip = document.createElement('span');
                chip.className = 'tag-chip';
                chip.innerHTML =
                    '<span>' + escapeHTML(v) + '</span>' +
                    '<button type="button" class="tag-remove" tabindex="-1" ' +
                    'data-idx="' + i + '" aria-label="Remove ' + escapeHTML(v) + '">&#x00D7;</button>';
                chip.querySelector('.tag-remove').addEventListener('click', function() {
                    values.splice(parseInt(this.dataset.idx, 10), 1);
                    sync();
                    render();
                });
                box.appendChild(chip);
            });

            // Draft input
            var inp = document.createElement('input');
            inp.className = 'tag-draft';
            inp.placeholder = values.length === 0 ? 'Type a value and press Enter\u2026' : 'Add another\u2026';
            inp.setAttribute('aria-label', 'Add value');
            inp.value = draftVal;

            inp.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    var v = inp.value.trim();
                    if (v && values.indexOf(v) === -1) {
                        values.push(v);
                    } else if (v && values.indexOf(v) !== -1) {
                        // Briefly flash the duplicate chip
                        var chips = box.querySelectorAll('.tag-chip');
                        chips.forEach(function(c) {
                            if (c.querySelector('span') && c.querySelector('span').textContent === v) {
                                c.style.outline = '2px solid var(--bs-warning)';
                                setTimeout(function(){ c.style.outline = ''; }, 600);
                            }
                        });
                    }
                    inp.value = '';
                    sync();
                    render();
                    // Return focus to new draft input
                    var newDraft = box.querySelector('.tag-draft');
                    if (newDraft) newDraft.focus();
                } else if (e.key === 'Backspace' && inp.value === '' && values.length > 0) {
                    values.pop();
                    sync();
                    render();
                    var newDraft = box.querySelector('.tag-draft');
                    if (newDraft) newDraft.focus();
                } else if (e.key === 'Escape') {
                    inp.value = '';
                }
            });

            // Also support comma as a separator: typing "foo," adds "foo"
            inp.addEventListener('input', function() {
                if (inp.value.endsWith(',')) {
                    var v = inp.value.slice(0, -1).trim();
                    if (v && values.indexOf(v) === -1) {
                        values.push(v);
                        inp.value = '';
                        sync();
                        render();
                        var newDraft = box.querySelector('.tag-draft');
                        if (newDraft) newDraft.focus();
                    } else {
                        inp.value = inp.value.slice(0, -1);
                    }
                }
            });

            box.appendChild(inp);
            if (draftVal) inp.focus();
        }

        // Clicking anywhere in the box focuses the draft input
        box.addEventListener('click', function(e) {
            if (e.target === box) {
                var draft = box.querySelector('.tag-draft');
                if (draft) draft.focus();
            }
        });

        render();
    }

    // Initialise all tag widgets present in a given root element
    function initAllTagInputs(root) {
        root.querySelectorAll('.tag-input-box[data-for]').forEach(function(box) {
            initTagInput(box.id, box.dataset.for);
        });
    }

    // Re-init after any HTMX content swap (accordion section load, row update after save/reset)
    document.body.addEventListener('htmx:afterSwap', function(e) {
        initAllTagInputs(e.target);
    });

    // Init any widgets already in the DOM on full page load
    document.addEventListener('DOMContentLoaded', function() {
        initAllTagInputs(document);
    });
</script>
{{end}}
