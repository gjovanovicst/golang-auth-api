{{define "api_key_edit_form"}}
<div class="card border-0 shadow-sm border-start border-primary border-3">
    <div class="card-body">
        <h6 class="fw-bold mb-3">
            <i class="bi bi-pencil-square me-2"></i>Edit API Key
        </h6>
        <div id="apikey-edit-alert"></div>
        <form hx-put="/gui/api-keys/{{.ID}}"
              hx-target="#apikey-edit-alert"
              hx-swap="innerHTML">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Key</label>
                    <p class="form-control-plaintext">
                        <code class="text-muted">{{.KeyPrefix}}...{{.KeySuffix}}</code>
                        {{if eq .KeyType "admin"}}
                        <span class="badge bg-danger bg-opacity-10 text-danger ms-1"><i class="bi bi-shield-lock me-1"></i>Admin</span>
                        {{else}}
                        <span class="badge bg-info bg-opacity-10 text-info ms-1"><i class="bi bi-app-indicator me-1"></i>App</span>
                        {{end}}
                    </p>
                </div>
                <div class="col-md-4">
                    <label for="editKeyName" class="form-label small text-muted">Name</label>
                    <input type="text" class="form-control" id="editKeyName" name="name"
                           value="{{.Name}}" required>
                </div>
                <div class="col-md-4">
                    <label for="editKeyDescription" class="form-label small text-muted">Description <span class="text-muted">(optional)</span></label>
                    <input type="text" class="form-control" id="editKeyDescription" name="description"
                           value="{{.Description}}" placeholder="Purpose of this key">
                </div>
            </div>
            <div class="row g-3 mt-0">
                <div class="col-md-8">
                    <label for="editKeyScopes" class="form-label small text-muted">Scopes <span class="text-muted">(optional)</span></label>
                    <input type="text" class="form-control" id="editKeyScopes" name="scopes"
                           value="{{.Scopes}}" placeholder="e.g. users:read,auth:*">
                    <div class="form-text">Comma-separated <code>resource:action</code> scopes. Leave blank for unrestricted access. Use <code>resource:*</code> for all actions on a resource.</div>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Save Changes
                </button>
                <button type="button" class="btn btn-outline-secondary"
                        hx-get="/gui/api-keys/form-cancel"
                        hx-target="#apikey-form-container"
                        hx-swap="innerHTML">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>
{{end}}
