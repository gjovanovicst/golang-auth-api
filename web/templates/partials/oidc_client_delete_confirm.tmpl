{{define "oidc_client_delete_confirm"}}
<div class="modal-body">
    <p>Are you sure you want to delete the OIDC client <strong>{{.Name}}</strong>?</p>
    <p class="text-muted small mb-0">
        <i class="bi bi-info-circle me-1"></i>
        Client ID: <code>{{.ClientID}}</code>. Any application using this client will immediately lose the ability to authenticate users through this provider.
    </p>
</div>
<div class="modal-footer border-0">
    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-danger btn-sm"
            hx-delete="/gui/oidc-clients/{{.ID}}"
            hx-target="#oidc-client-table"
            hx-swap="innerHTML">
        <i class="bi bi-trash me-1"></i>Delete Client
    </button>
</div>
{{end}}
