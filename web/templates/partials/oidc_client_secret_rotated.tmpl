{{define "oidc_client_secret_rotated"}}
<div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>
    <strong>Secret rotated successfully!</strong> Copy the new client secret now — it will not be shown again.
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    <div class="mt-2">
        <div class="input-group input-group-sm">
            <input type="text" class="form-control font-monospace" id="rotatedSecret" value="{{.PlainSecret}}" readonly>
            <button class="btn btn-outline-secondary" type="button"
                    onclick="navigator.clipboard.writeText('{{.PlainSecret}}').then(() => this.textContent='Copied!').catch(() => {})">
                <i class="bi bi-clipboard"></i>
            </button>
        </div>
        <div class="form-text">Client ID: <code>{{.ClientID}}</code></div>
    </div>
</div>
{{end}}
