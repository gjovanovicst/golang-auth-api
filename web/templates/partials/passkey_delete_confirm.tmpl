{{define "passkey_delete_confirm"}}
<div class="modal-body">
    <p>Are you sure you want to delete the passkey
        <strong>{{if .PasskeyName}}{{.PasskeyName}}{{else}}Unnamed passkey{{end}}</strong>
        from user <strong>{{.UserEmail}}</strong>?</p>
    <p class="text-muted small mb-0">
        <i class="bi bi-info-circle me-1"></i>
        The user will no longer be able to authenticate with this passkey. This action cannot be undone.
    </p>
</div>
<div class="modal-footer border-0">
    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-danger btn-sm"
            hx-delete="/gui/users/passkeys/{{.PasskeyID}}"
            hx-target="#user-detail-container"
            hx-swap="innerHTML">
        <i class="bi bi-trash me-1"></i>Delete Passkey
    </button>
</div>
{{end}}
