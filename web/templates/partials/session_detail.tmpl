{{define "session_detail"}}
<div class="card border-0 shadow-sm border-start border-primary border-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-broadcast me-2"></i>Session Details
            </h6>
            <button type="button" class="btn btn-sm btn-outline-secondary"
                    onclick="document.getElementById('session-detail-container').innerHTML = '';"
                    title="Close">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label small text-muted mb-1">User</label>
                    <div>
                        {{if .UserEmail}}
                        <span class="fw-semibold">{{.UserEmail}}</span>
                        {{else}}
                        <span class="text-muted fst-italic">Unknown user</span>
                        {{end}}
                        <br><small class="text-muted font-monospace">{{.UserID}}</small>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted mb-1">Application</label>
                    <div>
                        {{if .AppName}}
                        <span class="fw-semibold">{{.AppName}}</span>
                        {{else}}
                        <span class="text-muted fst-italic">Unknown app</span>
                        {{end}}
                        <br><small class="text-muted font-monospace">{{.AppID}}</small>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted mb-1">IP Address</label>
                    <div>
                        <span class="font-monospace">{{if .IP}}{{.IP}}{{else}}<span class="text-muted fst-italic">Not recorded</span>{{end}}</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label small text-muted mb-1">Created</label>
                    <div>{{.CreatedAt}}</div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted mb-1">Last Active</label>
                    <div>{{.LastActive}}</div>
                </div>
                <div class="mb-3">
                    <label class="form-label small text-muted mb-1">User Agent</label>
                    <div>
                        <small class="text-muted" style="word-break: break-all;">{{if .UserAgent}}{{.UserAgent}}{{else}}<span class="fst-italic">Not recorded</span>{{end}}</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="mt-3 pt-3 border-top d-flex justify-content-between align-items-center">
            <small class="text-muted font-monospace">Session ID: {{.SessionID}}</small>
            <div>
                <button class="btn btn-outline-danger btn-sm me-1"
                        hx-delete="/gui/sessions/{{.AppID}}/{{.SessionID}}?user_id={{.UserID}}"
                        hx-target="#session-table"
                        hx-swap="innerHTML"
                        hx-confirm="Revoke this session?"
                        title="Revoke this session">
                    <i class="bi bi-x-circle me-1"></i>Revoke Session
                </button>
                <button class="btn btn-outline-warning btn-sm"
                        hx-delete="/gui/sessions/revoke-all-user?app_id={{.AppID}}&user_id={{.UserID}}"
                        hx-target="#session-table"
                        hx-swap="innerHTML"
                        hx-confirm="Revoke ALL sessions for this user across this application?"
                        title="Revoke all sessions for this user">
                    <i class="bi bi-person-x me-1"></i>Revoke All for User
                </button>
            </div>
        </div>
    </div>
</div>
{{end}}
