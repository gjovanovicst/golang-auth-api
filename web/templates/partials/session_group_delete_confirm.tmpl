{{define "session_group_delete_confirm"}}
<div class="modal-body">
    <p>Are you sure you want to delete the session group <strong>{{.Name}}</strong>?</p>
    <p class="text-danger small mb-0">
        <i class="bi bi-exclamation-triangle me-1"></i>
        All app memberships in this group will be removed and SSO between those apps will stop working. This action cannot be undone.
    </p>
</div>
<div class="modal-footer border-0">
    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-danger btn-sm"
            hx-delete="/gui/session-groups/{{.ID}}"
            hx-target="#session-group-table"
            hx-swap="innerHTML"
            hx-headers='{"HX-Trigger-After-Swap": "sessionGroupDeleted"}'>
        <i class="bi bi-trash me-1"></i>Delete Session Group
    </button>
</div>
{{end}}
