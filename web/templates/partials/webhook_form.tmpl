{{define "webhook_form"}}
<div class="card border-0 shadow-sm border-start border-primary border-3">
    <div class="card-body">
        <h6 class="fw-bold mb-3">
            <i class="bi bi-plus-lg me-2"></i>Register Webhook Endpoint
        </h6>
        {{if .Error}}
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>{{.Error}}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        {{end}}
        <form hx-post="/gui/webhooks"
              hx-target="#webhook-created-container"
              hx-swap="innerHTML">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="webhookAppId" class="form-label small text-muted">Application</label>
                    <select class="form-select" id="webhookAppId" name="app_id" required>
                        <option value="">Select an application...</option>
                        {{range .Apps}}
                        <option value="{{.ID}}">{{.Name}} ({{.TenantName}})</option>
                        {{end}}
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="webhookEventType" class="form-label small text-muted">Event Type</label>
                    <select class="form-select" id="webhookEventType" name="event_type" required>
                        <option value="">Select event type...</option>
                        {{range .EventTypes}}
                        <option value="{{.}}">{{.}}</option>
                        {{end}}
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="webhookURL" class="form-label small text-muted">Endpoint URL</label>
                    <input type="url" class="form-control" id="webhookURL" name="url"
                           placeholder="https://your-server.com/webhook" required>
                    <div class="form-text">Must be a publicly reachable HTTPS URL.</div>
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-broadcast me-1"></i>Register Endpoint
                </button>
                <button type="button" class="btn btn-outline-secondary"
                        hx-get="/gui/webhooks/form-cancel"
                        hx-target="#webhook-form-container"
                        hx-swap="innerHTML">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>
{{end}}
